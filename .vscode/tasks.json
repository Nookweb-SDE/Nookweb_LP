{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev Server (Nookweb LP)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}", "env": {} },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "panel": "dedicated" },
      "runOptions": { "runOn": "folderOpen" }
    },
    {
      "label": "Abrir no Browser (Edge/Chrome)",
      "type": "shell",
      "command": "start http://localhost:5174",
      "windows": { "command": "start http://localhost:5174" },
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    }
  ]
}
