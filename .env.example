# Supabase (formulários, dados, base para Storage) — ver docs/SUPABASE.md
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Mostra seletor de idioma no build de producao (por padrao: apenas em dev)
# Build Docker (VPS): Dockerfile define VITE_ENABLE_LANGUAGE_SELECTOR=true por defeito.
# Vercel/outros: defina VITE_ENABLE_LANGUAGE_SELECTOR=true nas env vars do build.
# VITE_ENABLE_LANGUAGE_SELECTOR=true
# Fallback se Supabase não estiver configurado (ex.: Vercel api/contact)
VITE_API_URL=/api

# Habilita a rota /cases (galeria CasesModal) em build de produção — só para teste/preview
# VITE_ENABLE_CASES_MODAL=true
# Para Vercel API (contact):
# DATABASE_URL=
# DIRECT_URL=
# RESEND_API_KEY=
# Z_API_INSTANCE=
# Z_API_TOKEN=
# CONTACT_EMAIL=
# WHATSAPP_NUMBER=
